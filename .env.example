# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/lr_autotag

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llava:13b
OLLAMA_MAX_CONCURRENT=2
OLLAMA_TIMEOUT=120

# API Security
API_KEY=change-me-to-a-random-secret

# Image Processing
IMAGE_MAX_SIDE=1024
BATCH_CHUNK_SIZE=50
MAX_KEYWORDS=25
MAX_RETRY_ATTEMPTS=3

# Nominatim (Reverse Geocoding)
NOMINATIM_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=lr-autotag/1.0
